# Smart Public Transport Planner — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Transport Data API
API_KEY=your_api_key_here
BASE_URL=https://api.example-transit-provider.com/v1

# Application Settings
DEBUG=false
LOG_LEVEL=INFO
PORT=8501

# Optional: Database (if applicable)
# DATABASE_URL=sqlite:///transport.db
